datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique @db.VarChar(255)
  password_hash String    @db.VarChar(255)
  first_name    String    @db.VarChar(100)
  last_name     String    @db.VarChar(100)
  is_active     Boolean   @default(true)
  
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @updatedAt @db.Timestamptz
  deleted_at    DateTime? @db.Timestamptz
  created_by    String?   @db.Uuid
  updated_by    String?   @db.Uuid

  user_roles    UserRole[]
  driver_profile Driver?
  notifications Notification[]
  activity_logs ActivityLog[]
  audit_logs    AuditLog[]

  @@index([email])
  @@index([deleted_at])
  @@map("users")
}

model Role {
  id               String           @id @default(uuid()) @db.Uuid
  name             String           @db.VarChar(100)
  code             String           @unique @db.VarChar(50)
  description      String?          @db.VarChar(255)
  
  created_at       DateTime         @default(now()) @db.Timestamptz
  updated_at       DateTime         @updatedAt @db.Timestamptz
  deleted_at       DateTime?        @db.Timestamptz
  created_by       String?          @db.Uuid
  updated_by       String?          @db.Uuid

  user_roles       UserRole[]
  role_permissions RolePermission[]

  @@index([code])
  @@index([deleted_at])
  @@map("roles")
}

model Permission {
  id               String           @id @default(uuid()) @db.Uuid
  name             String           @db.VarChar(100)
  code             String           @unique @db.VarChar(50)
  description      String?          @db.VarChar(255)
  
  created_at       DateTime         @default(now()) @db.Timestamptz
  updated_at       DateTime         @updatedAt @db.Timestamptz
  deleted_at       DateTime?        @db.Timestamptz
  created_by       String?          @db.Uuid
  updated_by       String?          @db.Uuid

  role_permissions RolePermission[]

  @@index([code])
  @@index([deleted_at])
  @@map("permissions")
}

model UserRole {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  role_id    String    @db.Uuid
  
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([user_id, role_id])
  @@index([deleted_at])
  @@map("user_roles")
}

model RolePermission {
  id            String     @id @default(uuid()) @db.Uuid
  role_id       String     @db.Uuid
  permission_id String     @db.Uuid
  
  created_at    DateTime   @default(now()) @db.Timestamptz
  updated_at    DateTime   @updatedAt @db.Timestamptz
  deleted_at    DateTime?  @db.Timestamptz
  created_by    String?    @db.Uuid
  updated_by    String?    @db.Uuid

  role       Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_id])
  @@index([deleted_at])
  @@map("role_permissions")
}

model Vehicle {
  id           String    @id @default(uuid()) @db.Uuid
  plate_number String    @unique @db.VarChar(50)
  make         String    @db.VarChar(100)
  model        String    @db.VarChar(100)
  year         Int
  vin          String    @unique @db.VarChar(100)
  status       String    @db.VarChar(50) // active, inactive, maintenance
  
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz
  deleted_at   DateTime? @db.Timestamptz
  created_by   String?   @db.Uuid
  updated_by   String?   @db.Uuid

  trips        Trip[]
  maintenance  Maintenance[]
  expenses     Expense[]

  @@index([plate_number])
  @@index([deleted_at])
  @@map("vehicles")
}

model Driver {
  id             String    @id @default(uuid()) @db.Uuid
  user_id        String    @unique @db.Uuid
  license_number String    @unique @db.VarChar(100)
  license_expiry DateTime  @db.Date
  status         String    @db.VarChar(50) // active, inactive, suspended
  
  created_at     DateTime  @default(now()) @db.Timestamptz
  updated_at     DateTime  @updatedAt @db.Timestamptz
  deleted_at     DateTime? @db.Timestamptz
  created_by     String?   @db.Uuid
  updated_by     String?   @db.Uuid

  user  User   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  trips Trip[]

  @@index([deleted_at])
  @@map("drivers")
}

model Trip {
  id             String    @id @default(uuid()) @db.Uuid
  vehicle_id     String    @db.Uuid
  driver_id      String    @db.Uuid
  start_time     DateTime  @db.Timestamptz
  end_time       DateTime? @db.Timestamptz
  status         String    @db.VarChar(50) // scheduled, in_progress, completed, cancelled
  origin         String    @db.VarChar(255)
  destination    String    @db.VarChar(255)
  start_odometer Float
  end_odometer   Float?
  
  created_at     DateTime  @default(now()) @db.Timestamptz
  updated_at     DateTime  @updatedAt @db.Timestamptz
  deleted_at     DateTime? @db.Timestamptz
  created_by     String?   @db.Uuid
  updated_by     String?   @db.Uuid

  vehicle  Vehicle   @relation(fields: [vehicle_id], references: [id])
  driver   Driver    @relation(fields: [driver_id], references: [id])
  expenses Expense[]

  @@index([vehicle_id])
  @@index([driver_id])
  @@index([status])
  @@index([deleted_at])
  @@map("trips")
}

model MaintenanceType {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique @db.VarChar(100)
  description String?   @db.VarChar(255)
  
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz
  deleted_at  DateTime? @db.Timestamptz
  created_by  String?   @db.Uuid
  updated_by  String?   @db.Uuid

  maintenance Maintenance[]

  @@index([deleted_at])
  @@map("maintenance_types")
}

model Maintenance {
  id                  String    @id @default(uuid()) @db.Uuid
  vehicle_id          String    @db.Uuid
  maintenance_type_id String    @db.Uuid
  scheduled_date      DateTime  @db.Date
  completed_date      DateTime? @db.Date
  status              String    @db.VarChar(50) // scheduled, in_progress, completed, cancelled
  cost                Decimal?  @db.Decimal(10, 2)
  notes               String?   @db.Text
  
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz
  deleted_at          DateTime? @db.Timestamptz
  created_by          String?   @db.Uuid
  updated_by          String?   @db.Uuid

  vehicle          Vehicle         @relation(fields: [vehicle_id], references: [id])
  maintenance_type MaintenanceType @relation(fields: [maintenance_type_id], references: [id])

  @@index([vehicle_id])
  @@index([status])
  @@index([deleted_at])
  @@map("maintenance")
}

model FuelLog {
  id           String    @id @default(uuid()) @db.Uuid
  vehicle_id   String    @db.Uuid
  driver_id    String    @db.Uuid
  refuel_date  DateTime  @db.Timestamptz
  gallons      Decimal   @db.Decimal(10, 3)
  cost         Decimal   @db.Decimal(10, 2)
  odometer     Float
  
  created_at   DateTime  @default(now()) @db.Timestamptz
  updated_at   DateTime  @updatedAt @db.Timestamptz
  deleted_at   DateTime? @db.Timestamptz
  created_by   String?   @db.Uuid
  updated_by   String?   @db.Uuid

  @@index([vehicle_id])
  @@index([deleted_at])
  @@map("fuel_logs")
}

model ExpenseCategory {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique @db.VarChar(100)
  description String?   @db.VarChar(255)
  
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz
  deleted_at  DateTime? @db.Timestamptz
  created_by  String?   @db.Uuid
  updated_by  String?   @db.Uuid

  expenses Expense[]

  @@index([deleted_at])
  @@map("expense_categories")
}

model Expense {
  id                  String    @id @default(uuid()) @db.Uuid
  trip_id             String?   @db.Uuid
  vehicle_id          String?   @db.Uuid
  expense_category_id String    @db.Uuid
  amount              Decimal   @db.Decimal(10, 2)
  expense_date        DateTime  @db.Date
  notes               String?   @db.Text
  
  created_at          DateTime  @default(now()) @db.Timestamptz
  updated_at          DateTime  @updatedAt @db.Timestamptz
  deleted_at          DateTime? @db.Timestamptz
  created_by          String?   @db.Uuid
  updated_by          String?   @db.Uuid

  trip             Trip?           @relation(fields: [trip_id], references: [id])
  vehicle          Vehicle?        @relation(fields: [vehicle_id], references: [id])
  expense_category ExpenseCategory @relation(fields: [expense_category_id], references: [id])

  @@index([expense_category_id])
  @@index([deleted_at])
  @@map("expenses")
}

model Notification {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  title      String    @db.VarChar(150)
  message    String    @db.Text
  is_read    Boolean   @default(false)
  type       String    @db.VarChar(50) // alert, system, message
  
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([is_read])
  @@index([deleted_at])
  @@map("notifications")
}

model ActivityLog {
  id         String    @id @default(uuid()) @db.Uuid
  user_id    String?   @db.Uuid
  action     String    @db.VarChar(100)
  details    String?   @db.Text
  ip_address String?   @db.VarChar(45)
  user_agent String?   @db.VarChar(255)
  
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([deleted_at])
  @@map("activity_logs")
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  user_id     String?   @db.Uuid
  entity_name String    @db.VarChar(100)
  entity_id   String    @db.Uuid
  action      String    @db.VarChar(50) // CREATE, UPDATE, DELETE
  old_values  Json?     @db.JsonB
  new_values  Json?     @db.JsonB
  
  created_at  DateTime  @default(now()) @db.Timestamptz
  updated_at  DateTime  @updatedAt @db.Timestamptz
  deleted_at  DateTime? @db.Timestamptz
  created_by  String?   @db.Uuid
  updated_by  String?   @db.Uuid

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([entity_name, entity_id])
  @@index([deleted_at])
  @@map("audit_logs")
}

model File {
  id         String    @id @default(uuid()) @db.Uuid
  filename   String    @db.VarChar(255)
  mime_type  String    @db.VarChar(100)
  size       Int
  url        String    @db.VarChar(512)
  
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid

  @@index([deleted_at])
  @@map("files")
}

model Setting {
  id         String    @id @default(uuid()) @db.Uuid
  key        String    @unique @db.VarChar(100)
  value      String    @db.Text
  group      String    @db.VarChar(50)
  
  created_at DateTime  @default(now()) @db.Timestamptz
  updated_at DateTime  @updatedAt @db.Timestamptz
  deleted_at DateTime? @db.Timestamptz
  created_by String?   @db.Uuid
  updated_by String?   @db.Uuid

  @@index([group])
  @@index([deleted_at])
  @@map("settings")
}
